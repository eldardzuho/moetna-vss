# MoetnaVSS Environment Configuration
# =====================================

# Database - Coolify Hosted PostgreSQL
# Replace with your actual Coolify Postgres connection string
DATABASE_URL=postgres://user:password@your-coolify-host:5432/moetnavss?sslmode=require

# Redis (optional - for production event bus, caching, workflow engine)
# REDIS_URL=redis://your-coolify-host:6379

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-this
COOKIE_SECRET=your-super-secret-cookie-key-change-this

# Admin
ADMIN_CORS=http://localhost:9000,http://localhost:7001
STORE_CORS=http://localhost:8000

# Server
MEDUSA_BACKEND_URL=http://localhost:9000
PORT=9000

# File Storage (S3-compatible, optional)
# S3_FILE_URL=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=
# S3_BUCKET=

# Payment - Stripe (optional)
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=

# Notification - SendGrid (optional)
# SENDGRID_API_KEY=
# SENDGRID_FROM=
